---
import Base from '../layouts/Base.astro';

const courses = [
  {
    code: 'AFR-100',
    title: 'Rover Assembly & Teleoperation',
    phase: 'Phase 1 — Prototype',
    level: 'Foundation',
    hours: 40,
    prereqs: 'None',
    platform: 'SunFounder GalaxyRVR',
    cost: '$130 (kit)',
    description: 'Build a six-wheel rocker-bogie rover from a kit, learn basic Arduino programming, and operate the rover via FPV teleoperation. Covers mechanical assembly, motor control fundamentals, serial communication, and the SunFounder app for real-time driving.',
    outcomes: [
      'Assemble a rocker-bogie suspension rover from components',
      'Write Arduino sketches for motor control and sensor reading',
      'Configure ESP32 CAM for first-person video streaming',
      'Operate a rover remotely using a mobile control app',
      'Understand basic power budgeting and battery management',
    ],
    topics: [
      'Mechanical assembly & rocker-bogie kinematics',
      'Arduino Uno R3 programming (C++)',
      'DC motor drivers & PWM control',
      'ESP32 CAM configuration & Wi-Fi streaming',
      'Ultrasonic & infrared obstacle sensors',
      'Solar panel charging basics',
      'Serial communication protocols',
    ],
    project: 'Complete a timed obstacle course with the GalaxyRVR under manual FPV control. Document the build process and produce a wiring diagram.',
  },
  {
    code: 'AFR-200',
    title: 'Embedded Sensing & Data Collection',
    phase: 'Phase 2 — Sensor Integration',
    level: 'Intermediate',
    hours: 50,
    prereqs: 'AFR-100 or equivalent Arduino experience',
    platform: 'GalaxyRVR + sensor breakouts',
    cost: '$80 (sensors)',
    description: 'Integrate environmental and navigation sensors into the rover platform. Program an ESP32-S3 to poll GPS, IMU, temperature, humidity, pressure, and soil moisture sensors, then log and transmit structured telemetry.',
    outcomes: [
      'Interface I2C, SPI, and UART sensors with an ESP32-S3',
      'Fuse IMU data for orientation estimation',
      'Log GPS tracks and environmental measurements to onboard storage',
      'Transmit structured telemetry over Wi-Fi and LoRa',
      'Calibrate sensors for field conditions',
    ],
    topics: [
      'ESP32-S3 development with ESP-IDF & Arduino',
      'u-blox GNSS modules (ZED-F9P basics)',
      'IMU fusion — Bosch BNO085 / ICM-20948',
      'Environmental sensing — BME688 (T / H / P / VOC)',
      'Soil moisture & analog sensor interfacing',
      'Data logging to SD / SPI flash',
      'Telemetry protocols — JSON over MQTT / LoRa',
      'Sensor calibration & noise filtering',
    ],
    project: 'Conduct a 30-minute autonomous data-collection run, logging GPS waypoints, environmental readings, and IMU orientation to onboard storage. Produce a map overlay of the sensor data.',
  },
  {
    code: 'AFR-300',
    title: 'Computer Vision for Field Robotics',
    phase: 'Phase 2–3 — Perception',
    level: 'Intermediate',
    hours: 60,
    prereqs: 'AFR-100, basic Python',
    platform: 'Jetson Orin Nano + OAK-D or monocular camera',
    cost: '$350 (Jetson + camera)',
    description: 'Deploy computer vision on an edge compute platform. Covers stereo depth estimation, terrain classification with convolutional neural networks, and real-time obstacle detection — the perceptual foundation for autonomous navigation.',
    outcomes: [
      'Configure a Jetson Orin Nano for vision workloads',
      'Process stereo camera feeds for depth estimation',
      'Train and deploy a terrain classification model',
      'Implement real-time obstacle detection with bounding boxes',
      'Evaluate model performance on desert terrain imagery',
    ],
    topics: [
      'NVIDIA Jetson setup — JetPack, CUDA, TensorRT',
      'OpenCV fundamentals — image I/O, filtering, feature detection',
      'Stereo vision — OAK-D depth pipeline (DepthAI)',
      'Monocular depth estimation',
      'CNN-based terrain classification (sand, gravel, vegetation, rock)',
      'Object detection — YOLO / SSD on edge hardware',
      'Dataset collection & annotation for field environments',
      'Model optimization — quantization, pruning, TensorRT conversion',
    ],
    project: 'Train a terrain classifier on San Luis Valley imagery and deploy it on the Jetson. Demonstrate real-time classification at 10+ FPS on a live camera feed, distinguishing at least four terrain types.',
  },
  {
    code: 'AFR-400',
    title: 'Autonomous Navigation with ROS2',
    phase: 'Phase 3 — Autonomy',
    level: 'Advanced',
    hours: 80,
    prereqs: 'AFR-200, AFR-300 (or concurrent)',
    platform: 'ROS2 + Gazebo simulation, then rover hardware',
    cost: '$0 (simulation) / existing hardware',
    description: 'Build a full autonomous navigation stack using ROS2. Start in simulation with Gazebo, implement SLAM and path planning with Nav2, then transfer to the physical rover for waypoint missions in outdoor terrain.',
    outcomes: [
      'Architect a ROS2 system with nodes, topics, and services',
      'Simulate a rover in Gazebo with realistic terrain',
      'Implement SLAM using RTAB-Map or ORB-SLAM',
      'Configure Nav2 for path planning and obstacle avoidance',
      'Execute autonomous waypoint missions on physical hardware',
    ],
    topics: [
      'ROS2 architecture — nodes, topics, services, actions',
      'URDF / Xacro robot description',
      'Gazebo simulation — world building, sensor plugins',
      'tf2 coordinate transforms',
      'SLAM — RTAB-Map (visual) & ORB-SLAM (feature-based)',
      'Nav2 — costmaps, planners, controllers, behavior trees',
      'Localization — AMCL, EKF sensor fusion',
      'Sim-to-real transfer — tuning for outdoor conditions',
      'Mission planning — waypoint sequencing & recovery behaviors',
    ],
    project: 'Program the rover to autonomously navigate a 500m outdoor course with at least 5 waypoints, avoiding obstacles, and returning to the start position. Produce a SLAM-generated map of the traversed area.',
  },
  {
    code: 'AFR-500',
    title: 'Field Robotics Capstone',
    phase: 'Phase 4 — Field Deployment',
    level: 'Advanced',
    hours: 100,
    prereqs: 'AFR-200, AFR-300, AFR-400',
    platform: 'Full AFR platform',
    cost: 'Included (shared fleet)',
    description: 'Plan and execute a multi-day autonomous field mission in the San Luis Valley. Covers environmental hardening, power management for long-duration operation, communications infrastructure, data pipelines, and scientific data analysis.',
    outcomes: [
      'Prepare a rover for extended outdoor deployment (dust, wind, temperature)',
      'Design a power budget with solar charging for multi-day operation',
      'Deploy and manage field communications (Wi-Fi, LoRa, LTE)',
      'Execute a multi-day autonomous survey mission',
      'Build a data pipeline from rover to analysis workstation',
      'Produce a scientific report from collected field data',
    ],
    topics: [
      'Environmental hardening — IP-rated enclosures, filtered cooling, thermal management',
      'Power systems — LiFePO4 battery management, MPPT solar charging, power budgets',
      'Field communications — mesh Wi-Fi, LoRa telemetry, LTE failover, Starlink base station',
      'Mission planning — survey design, coverage algorithms, contingency handling',
      'Data pipelines — onboard logging, wireless sync, cloud ingest',
      'Geospatial analysis — GPS track processing, terrain model generation',
      'Environmental data analysis — time-series visualization, anomaly detection',
      'Field safety & logistics — site assessment, recovery procedures, regulatory compliance',
    ],
    project: 'Lead a 48-hour autonomous survey mission in the San Luis Valley. The rover must navigate a pre-planned route, collect environmental and terrain data, manage its own power via solar charging, and transmit telemetry to a base station. Deliver a field report with maps, environmental analysis, and lessons learned.',
  },
];

const levelColors: Record<string, string> = {
  Foundation: '#55c077',
  Intermediate: '#5588dd',
  Advanced: '#f0a830',
};
---

<Base title="Courses — Rover Micro-Credentials" description="Stackable micro-credential courses in field robotics: from rover assembly to autonomous navigation in the San Luis Valley.">

<!-- ─── NAV ──────────────────────────────────────────────── -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="brand-mark">AFR</span>
      <span class="brand-text">Autonomous Field Rover</span>
    </a>
    <div class="nav-links">
      <a href="/">Design</a>
      <a href="/courses" class="active">Courses</a>
    </div>
  </div>
</nav>

<!-- ─── HERO ─────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container">
    <div class="hero-badge">Castalia Institute &middot; Micro-Credentials</div>
    <h1>Field Robotics<br />Curriculum</h1>
    <p class="hero-sub">
      Five stackable micro-credentials that take you from assembling a rover kit
      to leading autonomous field missions in the San Luis Valley.
    </p>
  </div>
</section>

<!-- ─── PATHWAY ──────────────────────────────────────────── -->
<section class="pathway-section">
  <div class="container">
    <div class="pathway">
      {courses.map((c, i) => (
        <a href={`#${c.code.toLowerCase()}`} class="pathway-node">
          <span class="pathway-code">{c.code}</span>
          <span class="pathway-title">{c.title.split(' ').slice(0, 3).join(' ')}</span>
          {i < courses.length - 1 && <span class="pathway-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ─── COURSE CARDS ──────────────────────────────────────── -->
<section class="courses-section">
  <div class="container">
    {courses.map((c) => (
      <article id={c.code.toLowerCase()} class="course-card">
        <div class="course-header">
          <div class="course-meta-row">
            <span class="course-code">{c.code}</span>
            <span class="course-level" style={`--level-color: ${levelColors[c.level]}`}>{c.level}</span>
            <span class="course-phase">{c.phase}</span>
          </div>
          <h2>{c.title}</h2>
          <p class="course-desc">{c.description}</p>
          <div class="course-stats">
            <div class="stat">
              <span class="stat-value">{c.hours}</span>
              <span class="stat-label">Hours</span>
            </div>
            <div class="stat">
              <span class="stat-value">{c.cost}</span>
              <span class="stat-label">Materials</span>
            </div>
            <div class="stat">
              <span class="stat-value">{c.platform}</span>
              <span class="stat-label">Platform</span>
            </div>
            <div class="stat">
              <span class="stat-value">{c.prereqs}</span>
              <span class="stat-label">Prerequisites</span>
            </div>
          </div>
        </div>

        <div class="course-body">
          <div class="course-col">
            <h3>Learning Outcomes</h3>
            <ul class="outcome-list">
              {c.outcomes.map((o) => (
                <li>{o}</li>
              ))}
            </ul>
          </div>
          <div class="course-col">
            <h3>Topics Covered</h3>
            <ul class="topic-list">
              {c.topics.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="course-project">
          <h3>Capstone Project</h3>
          <p>{c.project}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- ─── CREDENTIAL STACK ──────────────────────────────────── -->
<section class="stack-section">
  <div class="container">
    <h2>Credential Structure</h2>
    <div class="stack-grid">
      <div class="stack-card">
        <h3>Individual Micro-Credentials</h3>
        <p>Each course awards a standalone micro-credential upon completion of the capstone project. Take any course independently if you meet the prerequisites.</p>
      </div>
      <div class="stack-card">
        <h3>Field Robotics Certificate</h3>
        <p>Complete all five micro-credentials (AFR-100 through AFR-500) to earn the Castalia Institute Field Robotics Certificate&mdash;330 hours of hands-on learning from assembly to autonomous field deployment.</p>
        <div class="total-hours">
          <span class="total-value">330</span>
          <span class="total-label">total hours</span>
        </div>
      </div>
      <div class="stack-card">
        <h3>Simulation Track</h3>
        <p>AFR-400 (Autonomous Navigation) can be completed entirely in simulation using ROS2 and Gazebo&mdash;no hardware required. Ideal for remote learners.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── FOOTER ────────────────────────────────────────────── -->
<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="brand-mark">AFR</span>
        <span>Castalia Institute</span>
      </div>
      <div class="footer-links">
        <a href="https://castalia.institute">castalia.institute</a>
        <a href="https://github.com/InquiryInstitute/rover.castalia.institute">GitHub</a>
      </div>
    </div>
  </div>
</footer>

</Base>

<style>
  /* ─── NAV ─────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(5, 5, 8, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-border);
  }
  .nav-inner {
    max-width: var(--max-w); margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-brand { display: flex; align-items: center; gap: 0.75rem; color: var(--c-text); }
  .brand-mark {
    font-family: var(--font-mono); font-weight: 700; font-size: 0.8rem;
    background: var(--c-accent); color: var(--c-bg);
    padding: 0.25rem 0.5rem; border-radius: 4px; letter-spacing: 0.05em;
  }
  .brand-text { font-size: 0.85rem; font-weight: 500; color: var(--c-text-muted); }
  .nav-links { display: flex; gap: 1.5rem; }
  .nav-links a {
    font-size: 0.8rem; font-weight: 500; color: var(--c-text-muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--c-accent); opacity: 1; }

  /* ─── PAGE HERO ───────────────────────────────── */
  .page-hero {
    padding: 8rem 0 4rem; text-align: center;
    background: linear-gradient(180deg, var(--c-surface) 0%, var(--c-bg) 100%);
    border-bottom: 1px solid var(--c-border);
  }
  .hero-badge {
    display: inline-block; font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--c-accent); margin-bottom: 1.5rem;
    border: 1px solid var(--c-accent-dim);
    padding: 0.4rem 1rem; border-radius: 100px;
    background: var(--c-accent-dim);
  }
  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700;
    line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem;
  }
  .hero-sub {
    font-size: 1.1rem; color: var(--c-text-muted);
    max-width: 560px; margin: 0 auto; line-height: 1.7;
  }

  /* ─── PATHWAY ─────────────────────────────────── */
  .pathway-section {
    padding: 2rem 0;
    border-bottom: 1px solid var(--c-border);
    background: var(--c-surface);
    overflow-x: auto;
  }
  .pathway {
    display: flex; align-items: center; justify-content: center;
    gap: 0.25rem; min-width: max-content; padding: 0 1rem;
  }
  .pathway-node {
    display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
    padding: 0.75rem 1rem; border-radius: 8px;
    transition: background 0.2s; color: var(--c-text);
    position: relative;
  }
  .pathway-node:hover { background: var(--c-surface-2); opacity: 1; }
  .pathway-code {
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600;
    color: var(--c-accent);
  }
  .pathway-title {
    font-size: 0.65rem; color: var(--c-text-muted); text-transform: uppercase;
    letter-spacing: 0.08em; white-space: nowrap;
  }
  .pathway-arrow {
    color: var(--c-border); display: flex; align-items: center;
    padding: 0 0.5rem;
  }

  /* ─── COURSES ─────────────────────────────────── */
  .courses-section { padding: 3rem 0; }
  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }

  .course-card {
    border: 1px solid var(--c-border); border-radius: 12px;
    background: var(--c-surface); margin-bottom: 2.5rem;
    overflow: hidden;
  }
  .course-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid var(--c-border);
    background: linear-gradient(135deg, var(--c-accent-dim) 0%, transparent 50%);
  }
  .course-meta-row {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 0.75rem; flex-wrap: wrap;
  }
  .course-code {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700;
    color: var(--c-accent);
  }
  .course-level {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; padding: 0.2rem 0.6rem; border-radius: 4px;
    background: color-mix(in srgb, var(--level-color) 15%, transparent);
    color: var(--level-color);
  }
  .course-phase {
    font-size: 0.7rem; color: var(--c-text-muted);
  }
  .course-header h2 {
    font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .course-desc {
    font-size: 0.95rem; color: var(--c-text-muted); line-height: 1.7;
    max-width: 720px;
  }
  .course-stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1rem; margin-top: 1.5rem;
  }
  .stat {
    padding: 0.75rem; border: 1px solid var(--c-border); border-radius: 8px;
    background: var(--c-surface-2);
  }
  .stat-value {
    display: block; font-size: 0.85rem; font-weight: 600;
    margin-bottom: 0.15rem; color: var(--c-text);
  }
  .stat-label {
    font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--c-text-muted);
  }

  .course-body {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    padding: 2rem;
  }
  .course-col h3 {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--c-accent); margin-bottom: 1rem;
  }
  .outcome-list, .topic-list { list-style: none; }
  .outcome-list li, .topic-list li {
    font-size: 0.85rem; color: var(--c-text-muted); padding: 0.35rem 0 0.35rem 1.25rem;
    position: relative; line-height: 1.5;
  }
  .outcome-list li::before {
    content: ''; position: absolute; left: 0; top: 0.7rem;
    width: 8px; height: 8px; border-radius: 50%;
    border: 2px solid var(--c-accent); background: transparent;
  }
  .topic-list li::before {
    content: ''; position: absolute; left: 0; top: 0.75rem;
    width: 8px; height: 2px; background: var(--c-border);
  }

  .course-project {
    padding: 1.5rem 2rem; border-top: 1px solid var(--c-border);
    background: var(--c-surface-2);
  }
  .course-project h3 {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--c-accent); margin-bottom: 0.5rem;
  }
  .course-project p { font-size: 0.9rem; color: var(--c-text-muted); line-height: 1.6; }

  /* ─── CREDENTIAL STACK ────────────────────────── */
  .stack-section {
    padding: 4rem 0; border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .stack-section h2 {
    font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }
  .stack-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .stack-card {
    padding: 1.5rem; border: 1px solid var(--c-border); border-radius: 10px;
    background: var(--c-surface-2);
  }
  .stack-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
  .stack-card p { font-size: 0.85rem; color: var(--c-text-muted); line-height: 1.6; }
  .total-hours {
    display: flex; align-items: baseline; gap: 0.5rem; margin-top: 1rem;
  }
  .total-value {
    font-family: var(--font-mono); font-size: 2rem; font-weight: 700;
    color: var(--c-accent);
  }
  .total-label { font-size: 0.8rem; color: var(--c-text-muted); }

  /* ─── FOOTER ──────────────────────────────────── */
  footer {
    padding: 2rem 0; border-top: 1px solid var(--c-border);
    background: var(--c-bg);
  }
  .footer-inner {
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-brand { display: flex; align-items: center; gap: 0.75rem; }
  .footer-brand span { font-size: 0.85rem; color: var(--c-text-muted); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.8rem; color: var(--c-text-muted); }

  /* ─── RESPONSIVE ──────────────────────────────── */
  @media (max-width: 1024px) {
    .course-stats { grid-template-columns: repeat(2, 1fr); }
    .stack-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .nav-links a:not(.active) { display: none; }
    .course-body { grid-template-columns: 1fr; }
    .course-stats { grid-template-columns: 1fr; }
    .course-header { padding: 1.5rem; }
    .course-body { padding: 1.5rem; }
    .course-project { padding: 1.5rem; }
    .footer-inner { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
